{
  "name": "pencil-login-theme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "theme:build": "node scripts/build-theme.mjs",
    "theme:build:dark": "set TOKEN_THEME=mode=dark&& node scripts/build-theme.mjs",
    "canvas:variables:once": "node scripts/sync-variables-from-pen.mjs",
    "canvas:variables:watch": "node scripts/sync-variables-from-pen.mjs --watch",
    "sync:canvas:once": "node scripts/sync-canvas-to-tokens.mjs",
    "sync:canvas:watch": "node scripts/sync-canvas-to-tokens.mjs --watch",
    "sync:all": "npm run sync:canvas:once && npm run theme:build",
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/input.css -o ./dist/output.css --minify",
    "dev:css": "tailwindcss -c tailwind.config.js -i ./src/input.css -o ./dist/output.css --watch",
    "dev": "concurrently \"npm:canvas:variables:watch\" \"npm:dev:css\"",
    "build": "npm run theme:build && npm run build:css"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tailwindcss": "^3.4.17"
  }
}
